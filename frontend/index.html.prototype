<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>A-SCHOOL — Générateur d'activités pédagogiques</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    :root {
      --bordeaux: #A63045;
      --bordeaux-dark: #832538;
      --bleu: #1F6EEB;
      --bleu-dark: #1558C0;
    }
    body { font-family: system-ui, -apple-system, sans-serif; }

    #sidebar { transition: width 0.2s ease; overflow: hidden; }
    #sidebar.collapsed { width: 48px; }
    #sidebar.collapsed .nav-label { display: none; }

    /* Focus rings bordeaux */
    select:focus, textarea:focus, input[type="number"]:focus {
      outline: 2px solid var(--bordeaux);
      outline-offset: 1px;
      border-color: var(--bordeaux) !important;
    }

    /* Checkbox bordeaux */
    #avec-correction { accent-color: var(--bordeaux); width: 16px; height: 16px; cursor: pointer; }

    /* Bouton primaire (Générer) */
    .btn-primary {
      display: inline-flex; align-items: center; gap: 6px;
      background-color: var(--bleu); color: white !important;
      border-radius: 6px; font-weight: 500; font-size: 0.875rem;
      padding: 0.45rem 1.1rem; transition: background 0.15s;
      border: none; cursor: pointer;
    }
    .btn-primary:hover { background-color: var(--bleu-dark); }

    /* Bouton action (Fichier, Dicter, Copier…) */
    .btn-action {
      display: inline-flex; align-items: center; gap: 6px;
      background-color: #E5E7EB; color: #374151;
      border: 1px solid #D1D5DB; border-radius: 6px;
      font-size: 0.8rem; font-weight: 500;
      padding: 0.45rem 0.85rem; transition: background 0.15s;
      cursor: pointer;
    }
    .btn-action:hover { background-color: #D1D5DB; }

    /* Bouton secondaire (Télécharger, Fermer) */
    .btn-secondary {
      display: inline-flex; align-items: center; gap: 6px;
      background: white; color: #374151;
      border: 1px solid #D1D5DB; border-radius: 6px;
      font-size: 0.8rem; font-weight: 500;
      padding: 0.4rem 0.85rem; transition: background 0.15s;
      cursor: pointer;
    }
    .btn-secondary:hover { background: #F9FAFB; }

    /* Bouton sidebar toggle */
    .btn-menu {
      display: flex; align-items: center; gap: 8px;
      width: 100%; padding: 1rem; text-align: left;
      color: #4B5563; font-weight: 500; font-size: 0.875rem;
      background: none; border: none; cursor: pointer;
      transition: background 0.15s;
    }
    .btn-menu:hover { background: #F9FAFB; }

    /* Nav active */
    .nav-link-active {
      color: var(--bordeaux) !important; font-weight: 600;
      border-left: 3px solid var(--bordeaux); padding-left: 9px;
    }

    /* Section title */
    .section-title {
      border-left: 3px solid var(--bordeaux); padding-left: 8px;
      font-size: 0.75rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.6px; color: #64748b;
    }

    /* Résultat */
    #zone-resultat { border-left: 4px solid var(--bordeaux); }

    select { appearance: auto; cursor: pointer; }
  </style>
</head>
<body class="bg-gray-100 flex flex-col min-h-screen">

  <!-- ═══ HEADER ═══ -->
  <header class="flex items-center justify-between px-6 py-4" style="background-color: var(--bleu);">
    <div class="flex items-center gap-3">
      <span class="text-white font-bold text-xl tracking-tight">
        <span style="color: var(--bordeaux);">A</span>-SCHOOL
      </span>
      <span class="text-white text-sm" style="opacity:0.65;">| Générateur d'activités pédagogiques</span>
    </div>
    <div class="flex items-center gap-4 text-sm">
      <span style="color: rgba(255,255,255,0.35);">|</span>
      <span id="nav-matiere" style="color: var(--bordeaux); font-weight: 600;">Français</span>
      <span style="color: rgba(255,255,255,0.35);">|</span>
      <span id="nav-email" style="color: rgba(255,255,255,0.6);">prof@ac-bordeaux.fr</span>
      <a href="#"
         style="color: white !important; border: 1px solid rgba(255,255,255,0.4); border-radius:6px; padding: 0.3rem 0.85rem; font-size:0.8rem; text-decoration:none; display:inline-flex; align-items:center; gap:5px;"
         title="Fermer votre session et revenir à la page de connexion">
        <!-- icône logout -->
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        Se déconnecter
      </a>
    </div>
  </header>

  <!-- ═══ MAIN LAYOUT ═══ -->
  <div class="flex flex-1 min-h-0">

    <!-- SIDEBAR -->
    <aside id="sidebar" class="w-44 bg-white border-r border-gray-200 flex flex-col shrink-0">
      <button onclick="toggleSidebar()" class="btn-menu" id="btn-sidebar"
              title="Cliquer pour réduire ou agrandir le menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        <span class="nav-label">Menu</span>
        <!-- chevron directionnel -->
        <svg id="sidebar-chevron" xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="nav-label ml-auto transition-transform"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <!-- Nav principale — haut -->
      <nav class="nav-label flex flex-col px-4 gap-1 text-sm flex-1">
        <a href="#" class="py-1.5 nav-link-active flex items-center gap-2"
           title="Page principale — générer une activité">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          Accueil
        </a>
        <a href="#" class="py-1.5 text-gray-500 hover:text-gray-800 flex items-center gap-2"
           title="Voir l'historique de vos générations précédentes">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          Historique
        </a>
      </nav>
      <!-- Nav secondaire — bas (style VS Code) -->
      <nav class="nav-label flex flex-col px-4 gap-1 text-sm pb-3 border-t border-gray-100 pt-3">
        <a href="#" class="py-1.5 text-gray-500 hover:text-gray-800 flex items-center gap-2"
           title="Consulter la documentation et l'aide en ligne">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          Aide
        </a>
        <a href="#" class="py-1.5 text-gray-500 hover:text-gray-800 flex items-center gap-2"
           title="Informations sur A-SCHOOL — version, équipe, contact">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          À propos
        </a>
      </nav>
    </aside>

    <!-- CONTENU PRINCIPAL -->
    <main class="flex-1 p-6 flex flex-col gap-6 overflow-auto">

      <!-- ── ZONE TEXTE ── -->
      <section class="bg-white rounded border border-gray-200 p-4">
        <div class="section-title mb-3">Texte source</div>
        <textarea
          id="texte-source"
          class="w-full border border-gray-300 rounded p-3 text-sm resize-y"
          rows="8"
          placeholder="Collez un extrait de texte ici&#10;— ou téléchargez un fichier .txt&#10;— ou importez un scan JPG/PNG&#10;— ou dictez avec le micro"
        ></textarea>
        <div class="mt-3 flex gap-2">
          <label class="btn-action"
                 title="Importer un fichier .txt ou un scan JPG/PNG — le texte sera extrait automatiquement">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
            Fichier .txt / scan JPG
            <input type="file" accept=".txt,.jpg,.jpeg,.png" class="hidden" onchange="chargerFichier(event)">
          </label>
          <button class="btn-action"
                  title="Cliquez pour dicter — parlez, puis cliquez à nouveau pour arrêter">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
            Dicter
          </button>
        </div>
      </section>

      <!-- ── PARAMÈTRES ── -->
      <section class="bg-white rounded border border-gray-200 p-4">
        <div class="section-title mb-4">Paramètres de l'activité</div>
        <div class="grid grid-cols-2 gap-4">

          <div>
            <label class="block text-xs text-gray-500 mb-1">Type d'activité</label>
            <select id="activite" onchange="updateSousTypes()"
                    class="w-full border border-gray-300 rounded p-2 text-sm">
            </select>
          </div>

          <div>
            <label class="block text-xs text-gray-500 mb-1">Niveau de la classe</label>
            <select id="niveau" class="w-full border border-gray-300 rounded p-2 text-sm">
              <option>6e</option><option>5e</option><option selected>4e</option>
              <option>3e</option><option>2nde</option><option>1ère</option>
              <option>Terminale</option><option>Supérieur</option>
            </select>
          </div>

          <div id="bloc-sous-type">
            <label class="block text-xs text-gray-500 mb-1">Précision</label>
            <select id="sous-type" class="w-full border border-gray-300 rounded p-2 text-sm"></select>
          </div>

          <div id="bloc-nb">
            <label class="block text-xs text-gray-500 mb-1">Nombre de questions</label>
            <input type="number" id="nb" min="1" max="20" value="5"
                   class="w-full border border-gray-300 rounded p-2 text-sm">
          </div>

        </div>

        <!-- Avec correction -->
        <div class="mt-4 flex items-start gap-2">
          <input type="checkbox" id="avec-correction" class="mt-0.5">
          <div>
            <label for="avec-correction" class="text-sm text-gray-700 cursor-pointer font-medium">
              Inclure une proposition de correction
            </label>
            <p class="text-xs text-gray-400 mt-0.5">
              A-SCHOOL génère une réponse-type après chaque question, que le professeur adapte à sa classe.
            </p>
          </div>
        </div>

        <div class="mt-5 flex justify-end">
          <button onclick="generer()" class="btn-primary"
                  title="Lancer la génération de l'activité avec l'IA">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            Générer l'activité
          </button>
        </div>
      </section>

      <!-- ── ZONE RÉSULTAT ── -->
      <section id="zone-resultat" class="bg-white rounded border border-gray-200 p-4 hidden">
        <div class="flex items-center justify-between mb-3">
          <div class="section-title">Résultat généré</div>
          <div class="flex gap-2">
            <button onclick="telechargerTxt()" class="btn-secondary"
                    title="Télécharger le résultat en fichier texte .txt">
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              Télécharger .txt
            </button>
            <button onclick="telechargerDocx()" class="btn-secondary"
                    title="Télécharger le résultat au format Word .docx">
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
              Télécharger Word
            </button>
            <button onclick="fermerResultat()" class="btn-secondary"
                    title="Fermer le résultat">
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              Fermer
            </button>
          </div>
        </div>
        <div id="resultat-content"
             class="text-sm text-gray-700 whitespace-pre-wrap leading-relaxed bg-blue-50 rounded p-4">
        </div>
      </section>

    </main>
  </div>

  <!-- ═══ FOOTER ═══ -->
  <footer class="bg-white border-t border-gray-200 px-6 py-3">
    <p class="text-center text-xs italic text-gray-400 mb-1">
      "Plus le monde s'ouvre, plus nous avons besoin de proximité..."
    </p>
    <div class="flex justify-between text-xs text-gray-400">
      <span>
        <span style="color: var(--bordeaux); font-weight: 600;">A</span>-SCHOOL
        · <a href="#" class="hover:underline">Mentions légales</a>
      </span>
      <span>v3.0-dev · contact : harketti@afia.fr</span>
    </div>
  </footer>

  <!-- ═══ SCRIPT ═══ -->
  <script>
    const ACTIVITES_FR = [
      { val:"comprehension",          label:"Questions de compréhension",      params:["nb","sous_type"], sous_types:["simples (repérage)","inférence","interprétation","personnages","décor / contexte","émotions / intentions","mélange"] },
      { val:"pistes",                 label:"Pistes de lecture",               params:["nb","sous_type"], sous_types:["thématique","narrateur","réalisme","point de vue","registre"] },
      { val:"resume",                 label:"Résumés",                         params:["sous_type"],      sous_types:["court (5 lignes)","structuré (début/milieu/fin)","pour l'oral"] },
      { val:"analyse",                label:"Analyse de texte",                params:["sous_type"],      sous_types:["thème principal","champs lexicaux","procédés d'écriture","passage difficile"] },
      { val:"reecriture",             label:"Exercices de réécriture",         params:["sous_type"],      sous_types:["style direct vers style indirect","passé simple vers présent","présent vers passé simple","présent vers conditionnel présent","1ère pers. sing. → 1ère pers. pluriel","3ème pers. sing. → 1ère pers. pluriel","changement de point de vue","simplifier le vocabulaire","enrichir le texte"] },
      { val:"vocabulaire",            label:"Étude de vocabulaire",            params:["sous_type"],      sous_types:["mots difficiles + définitions","synonymes / antonymes","exercices à trous","reformulation"] },
      { val:"production_ecrit",       label:"Production d'écrit",              params:["sous_type"],      sous_types:["paragraphe argumenté","continuer le texte","décrire un personnage","imaginer la suite d'une scène","texte poétique"] },
      { val:"oral",                   label:"Questions pour l'oral",           params:["nb","sous_type"], sous_types:["débat","exposé","échange en classe"] },
      { val:"grammaire",              label:"Exercices de grammaire",          params:["sous_type"],      sous_types:["temps verbaux","types de phrases","transformer des phrases","accords"] },
      { val:"fiche_pedagogique",      label:"Fiche pédagogique",               params:[],                 sous_types:[] },
      { val:"recherche_sequences",    label:"Recherche de séquences",          params:[],                 sous_types:[] },
      { val:"sequence_detaillee",     label:"Séquence détaillée",              params:[],                 sous_types:[] },
      { val:"questionnaire_roman",    label:"Questionnaire sur un roman",      params:[],                 sous_types:[] },
      { val:"evaluation_grammaire",   label:"Évaluation de grammaire",         params:[],                 sous_types:[] },
      { val:"evaluation_orthographe", label:"Évaluation d'orthographe",        params:[],                 sous_types:[] },
    ];

    const ACTIVITES_HG = [
      { val:"hg_comprehension",    label:"Questions sur un document",          params:["nb","sous_type"], sous_types:["identification","contexte","analyse","mise en relation","mélange"] },
      { val:"hg_analyse_source",   label:"Analyse de source",                  params:[],                 sous_types:[] },
      { val:"hg_questions_cours",  label:"Questions de cours",                 params:["nb","sous_type"], sous_types:["connaissances","définitions","explication","mélange"] },
      { val:"hg_frise",            label:"Frise chronologique",                params:[],                 sous_types:[] },
      { val:"hg_paragraphe",       label:"Paragraphe argumenté",               params:["sous_type"],      sous_types:["réponse organisée","SEUL","bilan de séquence"] },
      { val:"hg_fiche_revision",   label:"Fiche de révision",                  params:[],                 sous_types:[] },
      { val:"hg_composition",      label:"Composition / Dissertation",         params:["sous_type"],      sous_types:["introduction seule","plan détaillé","développement complet","plan avec transitions"] },
      { val:"hg_carte",            label:"Lecture de carte / Croquis",         params:["sous_type"],      sous_types:["décrire et expliquer une carte","questions sur un croquis","légende à compléter"] },
      { val:"hg_iconographie",     label:"Étude d'un document iconographique", params:["sous_type"],      sous_types:["affiche de propagande","dessin de presse","photographie historique","œuvre d'art"] },
      { val:"hg_reperes",          label:"Exercice de repères",                params:["nb","sous_type"], sous_types:["QCM de repères","définir des notions clés","placer des événements sur une frise","situer des lieux"] },
      { val:"hg_mise_en_relation", label:"Mise en relation de documents",      params:["sous_type"],      sous_types:["confronter deux sources","dégager complémentarité / contradiction","synthèse de documents"] },
      { val:"hg_oral",             label:"Préparation à l'oral",               params:["nb","sous_type"], sous_types:["exposé","débat","Grand Oral Terminale","échange en classe"] },
    ];

    const MATIERE_SESSION = "Français";
    const activitesList = MATIERE_SESSION === "Français" ? ACTIVITES_FR : ACTIVITES_HG;

    function getActiviteCourante() {
      return activitesList.find(a => a.val === document.getElementById("activite").value);
    }

    function init() {
      document.getElementById("nav-matiere").textContent = MATIERE_SESSION;
      const sel = document.getElementById("activite");
      activitesList.forEach(a => {
        const o = document.createElement("option");
        o.value = a.val; o.textContent = a.label;
        sel.appendChild(o);
      });
      updateSousTypes();
    }

    function updateSousTypes() {
      const act = getActiviteCourante();
      if (!act) return;
      const blocST = document.getElementById("bloc-sous-type");
      const blocNb = document.getElementById("bloc-nb");
      const selST  = document.getElementById("sous-type");

      if (act.sous_types.length > 0) {
        blocST.classList.remove("hidden");
        selST.innerHTML = "";
        act.sous_types.forEach(s => {
          const o = document.createElement("option");
          o.value = s; o.textContent = s; selST.appendChild(o);
        });
      } else {
        blocST.classList.add("hidden");
      }

      act.params.includes("nb")
        ? blocNb.classList.remove("hidden")
        : blocNb.classList.add("hidden");
    }

    function toggleSidebar() {
      const sidebar = document.getElementById("sidebar");
      sidebar.classList.toggle("collapsed");
      const chevron = document.getElementById("sidebar-chevron");
      chevron.style.transform = sidebar.classList.contains("collapsed") ? "rotate(180deg)" : "";
    }

    function chargerFichier(event) {
      const file = event.target.files[0];
      if (!file) return;
      const ext = file.name.split(".").pop().toLowerCase();
      if (ext === "txt") {
        const reader = new FileReader();
        reader.onload = e => { document.getElementById("texte-source").value = e.target.result; };
        reader.readAsText(file, "utf-8");
      } else {
        document.getElementById("texte-source").value = "(Scan « " + file.name + " » — OCR automatique via API)";
      }
    }

    function generer() {
      const texte = document.getElementById("texte-source").value.trim();
      if (!texte) { alert("Veuillez saisir un texte source."); return; }
      const zone = document.getElementById("zone-resultat");
      const content = document.getElementById("resultat-content");
      zone.classList.remove("hidden");
      content.textContent = "Génération en cours…";
      // TODO : POST /api/generate
    }

    function fermerResultat() {
      document.getElementById("zone-resultat").classList.add("hidden");
      document.getElementById("resultat-content").textContent = "";
    }

    function telechargerTxt() {
      const texte = document.getElementById("resultat-content").textContent;
      const a = document.createElement("a");
      a.href = URL.createObjectURL(new Blob([texte], { type:"text/plain;charset=utf-8" }));
      a.download = "activite.txt"; a.click();
    }

    function telechargerDocx() {
      alert("Export Word disponible une fois l'API branchée.");
    }

    init();
  </script>
</body>
</html>
