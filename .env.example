# Fournisseur IA — clé secrète uniquement.
# (Le fournisseur et le modèle sont des RÉGLAGES ADMIN : ils vivent en BASE,
#  changeables depuis l'écran d'administration, pas dans le .env.)
AI_API_KEY=ta_clé_groq_ici

# JWT — générer avec : python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production

# SMTP (envoi emails)
SMTP_HOST=mail.infomaniak.com
SMTP_PORT=587
SMTP_USERNAME=contact@aschool.fr
SMTP_PASSWORD=ton_mot_de_passe_smtp
SMTP_FROM=A-SCHOOL <contact@aschool.fr>
FEEDBACK_FROM=A-SCHOOL Feedback <feedback@aschool.fr>
FEEDBACK_NOTIFY_EMAIL=contact@aschool.fr

# App
APP_URL=https://aschool.fr
ADMIN_EMAIL=harketti@afia.fr

# Admin — accès au panneau d'administration (circuit séparé du login prof)
ADMIN_USERNAME=ton_identifiant_admin
ADMIN_PASSWORD=ton_mot_de_passe_admin

# Déploiement — réglages NON secrets qui changent selon la machine (dev / prod).
# Ne vivent PAS en base (config d'environnement, pas des réglages admin).

# Base de données PostgreSQL (psycopg). SQLite est banni : l'app refuse de démarrer
# sans une URL PostgreSQL ici. TEST_DATABASE_URL = base dédiée aux tests automatiques.
DATABASE_URL=postgresql+psycopg://user:mot_de_passe@localhost:5433/aschool
TEST_DATABASE_URL=postgresql+psycopg://user:mot_de_passe@localhost:5433/aschool_test

# Environnement : "production" active les cookies sécurisés (HTTPS). Vide/absent = dev.
ENV=development

# Filtre d'inscription (optionnel) : liste d'emails autorisés à créer un compte,
# séparés par des virgules. VIDE = inscription ouverte à tous (comportement par défaut).
ALLOWED_EMAILS=

# Régulation des appels LLM sortants (infra). Défauts code : 8 et 30.
AI_MAX_CONCURRENCY=8
AI_SLOT_TIMEOUT=30

# Origines CORS autorisées (liste séparée par des virgules). VIDE / absente = défaut code
# (localhost dev + https://aschool.fr). En prod, garder https://aschool.fr.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://aschool.fr
