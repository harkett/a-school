# Fournisseur IA
AI_PROVIDER=groq
AI_API_KEY=ta_clé_groq_ici
AI_MODEL=llama-3.3-70b-versatile

# ============================================================
# Dictée vocale (STT — Speech To Text) — Provider Deepgram Nova-3
# Spec : MesMD/DEEPGRAM/SPEC_DEEPGRAM_STT.md
# ============================================================

# Provider STT actif
STT_PROVIDER=deepgram

# Identifiants Deepgram (JAMAIS en clair dans le code committé)
DEEPGRAM_API_KEY=[DEEPGRAM_API_KEY]
DEEPGRAM_PROJECT_ID=[DEEPGRAM_PROJECT_ID]

# Modèle et région (Phase 1 = US, voir §3.4 spec pour conditions de migration EU)
DEEPGRAM_MODEL=nova-3
DEEPGRAM_REGION=us
DEEPGRAM_API_KEY_EXPIRES_AT=2026-08-14

# Paramètres Deepgram (MVP : .env ; V2 : éditables en admin)
DEEPGRAM_LANGUAGE=fr
DEEPGRAM_SMART_FORMAT=true
DEEPGRAM_INTERIM_RESULTS=true
DEEPGRAM_ENDPOINTING_MS=800
DEEPGRAM_DICTATION=false
DEEPGRAM_PUNCTUATE=true

# Limites concurrence et timeouts session
STT_MAX_CONCURRENT_SESSIONS=40
STT_SESSION_IDLE_TIMEOUT_SECONDS=30
STT_SESSION_MAX_DURATION_SECONDS=300

# Monitoring crédit Deepgram
STT_INITIAL_CREDIT_USD=200
STT_CREDIT_ALERT_THRESHOLD_PCT=10

# Mode des messages utilisateur (neutral en Phase 1)
STT_MESSAGE_MODE=neutral

# JWT — générer avec : python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production

# SMTP (envoi emails)
SMTP_HOST=mail.infomaniak.com
SMTP_PORT=587
SMTP_USERNAME=contact@aschool.fr
SMTP_PASSWORD=ton_mot_de_passe_smtp
SMTP_FROM=A-SCHOOL <contact@aschool.fr>
FEEDBACK_FROM=A-SCHOOL Feedback <feedback@aschool.fr>
FEEDBACK_NOTIFY_EMAIL=contact@aschool.fr

# App
APP_URL=https://school.afia.fr
ADMIN_EMAIL=harketti@afia.fr

# Admin — accès au panneau d'administration (circuit séparé du login prof)
ADMIN_USERNAME=ton_identifiant_admin
ADMIN_PASSWORD=ton_mot_de_passe_admin
