# Fournisseurs IA — clés secrètes, UNE PAR USAGE FACTURÉ (pour obtenir des
# statistiques par usage sur le tableau de bord du fournisseur). Le fournisseur et
# le modèle texte ACTIFS sont des RÉGLAGES ADMIN en BASE (écran Génération LLM) ;
# le .env ne sert que de repli optionnel au boot (voir AI_PROVIDER / AI_MODEL plus bas).
# Le NOM des variables OCR / dictée est lu EN BASE (settings.cle_env_ocr /
# cle_env_dictee) ; le .env ne porte QUE le secret. NE JAMAIS nommer une clé
# « ANTHROPIC_API_KEY » : Claude Code la lirait → facturation croisée.
#
# OCR (image / scan) :
GROQ_API_KEY_OCR=ta_clé_groq_ocr_ici
# Dictée vocale (Whisper) :
GROQ_API_KEY_DICTEE=ta_clé_groq_dictee_ici
# Texte — Anthropic (fournisseur texte par défaut aujourd'hui) :
CLAUDE_API_KEY_TEXTE=ta_clé_anthropic_ici
# Optionnelle — uniquement si le fournisseur texte est réglé sur Groq :
GROQ_API_KEY=ta_clé_groq_texte_ici

# JWT — générer avec : python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production
# JWT admin — secret DISTINCT du JWT_SECRET prof (isolation des tokens admin).
# Si absent, repli automatique sur JWT_SECRET (transition sans casse). Le poser invalide
# les sessions admin en cours → reconnexion admin, désormais isolée. Générer comme ci-dessus.
ADMIN_JWT_SECRET=change-me-in-production-admin

# SMTP (envoi emails)
SMTP_HOST=mail.infomaniak.com
SMTP_PORT=587
SMTP_USERNAME=contact@aschool.fr
SMTP_PASSWORD=ton_mot_de_passe_smtp
SMTP_FROM=A-SCHOOL <contact@aschool.fr>
FEEDBACK_FROM=A-SCHOOL Feedback <feedback@aschool.fr>
FEEDBACK_NOTIFY_EMAIL=contact@aschool.fr

# App
APP_URL=https://aschool.fr
ADMIN_EMAIL=ton_email_admin@exemple.fr

# Admin — accès au panneau d'administration (circuit séparé du login prof)
ADMIN_USERNAME=ton_identifiant_admin
ADMIN_PASSWORD=ton_mot_de_passe_admin

# Déploiement — réglages NON secrets qui changent selon la machine (dev / prod).
# Ne vivent PAS en base (config d'environnement, pas des réglages admin).

# Base de données PostgreSQL (psycopg). SQLite est banni : l'app refuse de démarrer
# sans une URL PostgreSQL ici. TEST_DATABASE_URL = base dédiée aux tests automatiques.
DATABASE_URL=postgresql+psycopg://user:mot_de_passe@localhost:5433/aschool
TEST_DATABASE_URL=postgresql+psycopg://user:mot_de_passe@localhost:5433/aschool_test

# Environnement : "production" active les cookies sécurisés (HTTPS). Vide/absent = dev.
ENV=development

# Filtre d'inscription (optionnel) : liste d'emails autorisés à créer un compte,
# séparés par des virgules. VIDE = inscription ouverte à tous (comportement par défaut).
ALLOWED_EMAILS=

# Régulation des appels LLM sortants (infra). Défauts code : 8 et 30.
AI_MAX_CONCURRENCY=8
AI_SLOT_TIMEOUT=30

# Fournisseur / modèle texte par DÉFAUT — OPTIONNELS. La source normale est l'écran
# admin « Génération LLM » (en base) : ces valeurs ne servent que de repli si generate()
# est appelé sans provider/modèle (rétro-compat). Défauts code : groq / llama-3.3-70b-versatile.
AI_PROVIDER=groq
AI_MODEL=llama-3.3-70b-versatile

# Origines CORS autorisées (liste séparée par des virgules). VIDE / absente = défaut code
# (localhost dev + https://aschool.fr). En prod, garder https://aschool.fr.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://aschool.fr

# VITE_API_PORT (frontend) : port du backend visé par le proxy Vite. N'est PAS lu depuis
# ce .env — Scripts/run.ps1 l'injecte dans l'environnement (option -BackendPort) avant
# « npm run dev ». Mentionné ici pour mémoire ; le définir dans ce fichier n'a aucun effet.
